{
  "name": "@equinor/fusion-framework-cli-plugin-copilot",
  "version": "1.1.0",
  "description": "Copilot SDK powered evaluation plugin for Fusion Framework CLI",
  "type": "module",
  "main": "dist/esm/index.js",
