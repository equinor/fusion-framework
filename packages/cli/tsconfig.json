{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/esm",
    "rootDir": "src",
    "declarationDir": "./dist/types",
    "paths": {
      "*": ["./*"]
    }
  },
  "references": [
    {
      "path": "../modules/module"
    },
    {
      "path": "../modules/azure-identity"
    },
    {
      "path": "../utils/imports"
    },
    {
      "path": "../modules/http"
    },
    {
      "path": "../modules/service-discovery"
    },
    {
      "path": "../modules/app"
    },
    {
      "path": "../app"
    },
    {
      "path": "../dev-server"
    },
    {
      "path": "../react/router"
    },
    {
      "path": "../vite-plugins/raw-imports"
    }
  ],
  "include": ["src/**/*", "types/*"],
  "exclude": ["node_modules"]
}
